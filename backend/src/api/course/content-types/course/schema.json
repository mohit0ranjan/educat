{
  "kind": "collectionType",
  "collectionName": "courses",
  "info": {
    "singularName": "course",
    "pluralName": "courses",
    "displayName": "Course",
    "description": "Educational course"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "richtext"
    },
    "instructor": {
      "type": "string"
    },
    "thumbnailUrl": {
      "type": "string"
    },
    "modules": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::module.module",
      "mappedBy": "course"
    },
    "announcements": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::announcement.announcement",
      "mappedBy": "course"
    },
    "liveClasses": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::live-class.live-class",
      "mappedBy": "course"
    },
    "teacher": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "lectures": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::lecture.lecture",
      "mappedBy": "course"
    }
  }
}